{
  "name": "@randsum/notation",
  "description": "Zero-dependency dice notation parser, validator, and type system for JavaScript and TypeScript",
  "version": "3.5.0",
  "type": "module",
  "private": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "module": "./dist/index.js",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./parse": {
      "import": {
        "types": "./dist/parse.d.ts",
        "default": "./dist/parse.js"
      },
      "require": {
        "types": "./dist/parse.d.cts",
        "default": "./dist/parse.cjs"
      }
    },
    "./validate": {
      "import": {
        "types": "./dist/validate.d.ts",
        "default": "./dist/validate.js"
      },
      "require": {
        "types": "./dist/validate.d.cts",
        "default": "./dist/validate.cjs"
      }
    },
    "./transform": {
      "import": {
        "types": "./dist/transform.d.ts",
        "default": "./dist/transform.js"
      },
      "require": {
        "types": "./dist/transform.d.cts",
        "default": "./dist/transform.cjs"
      }
    },
    "./schemas": {
      "import": {
        "types": "./dist/schemas.d.ts",
        "default": "./dist/schemas.js"
      },
      "require": {
        "types": "./dist/schemas.d.cts",
        "default": "./dist/schemas.cjs"
      }
    },
    "./tokenize": {
      "import": {
        "types": "./dist/tokenize.d.ts",
        "default": "./dist/tokenize.js"
      },
      "require": {
        "types": "./dist/tokenize.d.cts",
        "default": "./dist/tokenize.cjs"
      }
    },
    "./comparison": {
      "import": {
        "types": "./dist/comparison/index.d.ts",
        "default": "./dist/comparison/index.js"
      },
      "require": {
        "types": "./dist/comparison/index.d.cts",
        "default": "./dist/comparison/index.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types.d.ts",
        "default": "./dist/types.js"
      },
      "require": {
        "types": "./dist/types.d.cts",
        "default": "./dist/types.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "author": {
    "name": "Alex Jarvis",
    "url": "https://github.com/alxjrvs"
  },
  "license": "MIT",
  "homepage": "https://randsum.dev/packages/notation/",
  "bugs": "https://github.com/RANDSUM/randsum/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RANDSUM/randsum.git",
    "directory": "packages/notation"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=18.0.0"
  },
  "keywords": [
    "dice",
    "notation",
    "rpg",
    "parser",
    "typescript",
    "ttrpg",
    "randsum",
    "dice-notation",
    "dice-roller",
    "tabletop",
    "game-development",
    "validation",
    "zero-dependency"
  ],
  "dependencies": {},
  "devDependencies": {},
  "scripts": {
    "dev": "bunup --watch",
    "prepublishOnly": "bun run build",
    "build": "bunup",
    "test": "bun test",
    "lint": "eslint . -c ../../eslint.config.js",
    "format": "prettier --write . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "check:exports": "ts-unused-exports ../../tsconfig.json --ignoreFiles='__tests__|test-utils|[\\\\/]dist[\\\\/]' --maxIssues=50",
    "check": "bun run build && bun run typecheck && bun run format:check && bun run lint && bun run test && bun run size && bun run check:exports"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "13 KB"
    },
    {
      "path": "dist/index.d.ts",
      "limit": "4 KB"
    }
  ]
}
