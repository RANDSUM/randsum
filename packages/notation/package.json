{
  "name": "@randsum/notation",
  "version": "3.5.0",
  "description": "Zero-dependency dice notation parser, validator, and type system for JavaScript and TypeScript",
  "private": false,
  "author": {
    "name": "Alex Jarvis",
    "url": "https://github.com/alxjrvs"
  },
  "license": "MIT",
  "sideEffects": false,
  "homepage": "https://randsum.dev/packages/notation/",
  "bugs": "https://github.com/RANDSUM/randsum/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RANDSUM/randsum.git",
    "directory": "packages/notation"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./parse": {
      "import": {
        "types": "./dist/parse.d.ts",
        "default": "./dist/parse.js"
      },
      "require": {
        "types": "./dist/parse.d.cts",
        "default": "./dist/parse.cjs"
      }
    },
    "./validate": {
      "import": {
        "types": "./dist/validate.d.ts",
        "default": "./dist/validate.js"
      },
      "require": {
        "types": "./dist/validate.d.cts",
        "default": "./dist/validate.cjs"
      }
    },
    "./transform": {
      "import": {
        "types": "./dist/transform.d.ts",
        "default": "./dist/transform.js"
      },
      "require": {
        "types": "./dist/transform.d.cts",
        "default": "./dist/transform.cjs"
      }
    },
    "./comparison": {
      "import": {
        "types": "./dist/comparisonExports.d.ts",
        "default": "./dist/comparisonExports.js"
      },
      "require": {
        "types": "./dist/comparisonExports.d.cts",
        "default": "./dist/comparisonExports.cjs"
      }
    },
    "./schemas": {
      "import": {
        "types": "./dist/schemas.d.ts",
        "default": "./dist/schemas.js"
      },
      "require": {
        "types": "./dist/schemas.d.cts",
        "default": "./dist/schemas.cjs"
      }
    },
    "./tokenize": {
      "import": {
        "types": "./dist/tokenizeExports.d.ts",
        "default": "./dist/tokenizeExports.js"
      },
      "require": {
        "types": "./dist/tokenizeExports.d.cts",
        "default": "./dist/tokenizeExports.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/publicTypes.d.ts",
        "default": "./dist/publicTypes.js"
      },
      "require": {
        "types": "./dist/publicTypes.d.cts",
        "default": "./dist/publicTypes.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=18.0.0"
  },
  "keywords": [
    "dice",
    "notation",
    "rpg",
    "parser",
    "typescript",
    "ttrpg",
    "randsum",
    "dice-notation",
    "dice-roller",
    "tabletop",
    "game-development",
    "validation",
    "zero-dependency"
  ],
  "dependencies": {},
  "devDependencies": {},
  "scripts": {
    "dev": "bunup --watch",
    "prepublishOnly": "bun run build",
    "build": "bunup --entry src/index.ts --entry src/parse.ts --entry src/validate.ts --entry src/transform.ts --entry src/comparisonExports.ts --entry src/schemas.ts --entry src/tokenizeExports.ts --entry src/publicTypes.ts --format esm,cjs --dts --no-splitting --minify --sourcemap external --target node --clean",
    "test": "bun test",
    "lint": "eslint . -c ../../eslint.config.js",
    "format": "prettier --write . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "typecheck": "tsc --noEmit"
  }
}
