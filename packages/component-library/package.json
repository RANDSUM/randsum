{
  "name": "@randsum/component-library",
  "description": "React component library for RANDSUM dice rolling tools",
  "version": "3.5.0",
  "type": "module",
  "private": false,
  "files": [
    "dist",
    "!dist/**/*.map",
    "LICENSE",
    "README.md"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "author": {
    "name": "Alex Jarvis",
    "url": "https://github.com/alxjrvs"
  },
  "license": "MIT",
  "homepage": "https://randsum.dev/packages/component-library/",
  "bugs": "https://github.com/RANDSUM/randsum/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RANDSUM/randsum.git",
    "directory": "packages/component-library"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@randsum/roller": "^3.5.0"
  },
  "devDependencies": {
    "@ladle/react": "5.1.1",
    "@randsum/display-utils": "workspace:~",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=18.0.0"
  },
  "keywords": [
    "dice",
    "roller",
    "rpg",
    "react",
    "components",
    "randsum"
  ],
  "scripts": {
    "dev": "bunup --watch",
    "prepublishOnly": "bun run build",
    "build": "bunup",
    "test": "bun test",
    "lint": "eslint . -c ../../eslint.config.js",
    "format": "prettier --write . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "typecheck": "tsc --noEmit",
    "ladle": "ladle serve",
    "ladle:build": "ladle build",
    "size": "size-limit",
    "check": "bun run build && bun run typecheck && bun run format:check && bun run lint && bun run test"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "50 KB"
    }
  ]
}
