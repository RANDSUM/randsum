{
  "name": "@randsum/gameSchema",
  "version": "0.1.0",
  "description": "JSON Schema definition, runtime loader, and code generator for the randsum dice mechanic spec format (.randsum.json)",
  "private": true,
  "author": {
    "name": "Alex Jarvis",
    "url": "https://github.com/alxjrvs"
  },
  "license": "MIT",
  "homepage": "https://randsum.dev/packages/gameSchema/",
  "bugs": "https://github.com/RANDSUM/randsum/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RANDSUM/randsum.git",
    "directory": "packages/gameSchema"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "randsum-schema-validate": "./dist/bin.cjs",
    "randsum-schema-build": "./dist/bin-build.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./randsum.json": "./randsum.json"
  },
  "files": [
    "dist",
    "randsum.json"
  ],
  "dependencies": {
    "ajv": "8.18.0"
  },
  "peerDependencies": {
    "@randsum/roller": "^3.0.0"
  },
  "devDependencies": {
    "@randsum/roller": "workspace:~",
    "typescript": "^5.9.3",
    "bunup": "^0.16.0",
    "prettier": "^3.8.1"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "bunup --watch",
    "prepublishOnly": "bun run build",
    "build": "bunup && chmod +x dist/bin.cjs dist/bin-build.js",
    "codegen": "bun scripts/codegen.ts",
    "validate": "bun src/bin.ts",
    "test": "bun run build && bun test",
    "lint": "eslint . -c ../../eslint.config.js",
    "format": "prettier --write . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "typecheck": "tsc --noEmit"
  }
}
