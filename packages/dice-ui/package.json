{
  "name": "@randsum/dice-ui",
  "version": "2.0.0",
  "description": "React UI components for RANDSUM dice rolling — notation input with token overlay, roll step visualizer, and combined roller",
  "private": true,
  "license": "MIT",
  "homepage": "https://randsum.dev",
  "bugs": "https://github.com/RANDSUM/randsum/issues",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@randsum/roller": "workspace:~"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "20.10.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint . -c ../../eslint.config.js",
    "format": "prettier --write . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "test": "bun test __tests__",
    "test:coverage": "bun test __tests__ --coverage --coverage-reporter=lcov --coverage-dir=./coverage",
    "check": "bun run typecheck && bun run format:check && bun run lint && bun run test"
  }
}
