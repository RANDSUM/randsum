{
  "name": "@randsum/display-utils",
  "version": "3.5.0",
  "description": "Tooltip steps, modifier docs, and StackBlitz scaffolding for RANDSUM UIs",
  "private": true,
  "author": {
    "name": "Alex Jarvis",
    "url": "https://github.com/alxjrvs"
  },
  "license": "MIT",
  "sideEffects": false,
  "homepage": "https://randsum.dev/packages/display-utils/",
  "bugs": "https://github.com/RANDSUM/randsum/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RANDSUM/randsum.git",
    "directory": "packages/display-utils"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=18.0.0"
  },
  "keywords": [
    "dice",
    "randsum",
    "display",
    "utilities"
  ],
  "peerDependencies": {
    "@randsum/roller": "^3.5.0"
  },
  "devDependencies": {
    "@randsum/roller": "workspace:~",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "dev": "bunup --watch",
    "build": "bunup",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "eslint . -c ../../eslint.config.js",
    "format": "prettier --write . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore --config ../../.prettierrc"
  }
}
