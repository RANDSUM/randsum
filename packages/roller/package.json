{
  "name": "@randsum/roller",
  "description": "TypeScript-first dice notation engine for tabletop RPGs, game development, and probability simulations",
  "version": "3.5.0",
  "type": "module",
  "private": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "module": "./dist/index.js",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./roll": {
      "import": {
        "types": "./dist/roll/index.d.ts",
        "default": "./dist/roll/index.js"
      },
      "require": {
        "types": "./dist/roll/index.d.cts",
        "default": "./dist/roll/index.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/types/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.cts",
        "default": "./dist/types/index.cjs"
      }
    },
    "./validate": {
      "import": {
        "types": "./dist/validate.d.ts",
        "default": "./dist/validate.js"
      },
      "require": {
        "types": "./dist/validate.d.cts",
        "default": "./dist/validate.cjs"
      }
    },
    "./errors": {
      "import": {
        "types": "./dist/errors.d.ts",
        "default": "./dist/errors.js"
      },
      "require": {
        "types": "./dist/errors.d.cts",
        "default": "./dist/errors.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "author": {
    "name": "Alex Jarvis",
    "url": "https://github.com/alxjrvs"
  },
  "license": "MIT",
  "homepage": "https://randsum.dev/packages/roller/",
  "bugs": "https://github.com/RANDSUM/randsum/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RANDSUM/randsum.git",
    "directory": "packages/roller"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=18.0.0"
  },
  "keywords": [
    "dice",
    "roller",
    "rpg",
    "random",
    "typescript",
    "dnd",
    "tabletop",
    "dice-roller",
    "ttrpg",
    "dungeons-and-dragons",
    "pathfinder",
    "game-development",
    "board-games",
    "role-playing-games",
    "probability",
    "simulation",
    "randsum"
  ],
  "dependencies": {
    "@randsum/notation": "workspace:~"
  },
  "devDependencies": {
    "fast-check": "catalog:"
  },
  "scripts": {
    "dev": "bunup --watch",
    "prepublishOnly": "bun run build",
    "build": "bunup",
    "test": "bun test",
    "lint": "eslint . -c ../../eslint.config.js",
    "format": "prettier --write . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "check:exports": "ts-unused-exports ../../tsconfig.json --ignoreFiles='__tests__|test-utils|[\\\\/]dist[\\\\/]' --maxIssues=50",
    "check": "bun run build && bun run typecheck && bun run format:check && bun run lint && bun run test && bun run size && bun run check:exports"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "10 KB"
    },
    {
      "path": "dist/index.d.ts",
      "limit": "5 KB"
    }
  ]
}
