{
  "name": "@randsum/roller",
  "version": "3.5.0",
  "description": "TypeScript-first dice notation engine for tabletop RPGs, game development, and probability simulations",
  "private": false,
  "author": {
    "name": "Alex Jarvis",
    "url": "https://github.com/alxjrvs"
  },
  "license": "MIT",
  "sideEffects": [
    "./dist/index.js",
    "./dist/index.cjs"
  ],
  "homepage": "https://randsum.dev/packages/roller/",
  "bugs": "https://github.com/RANDSUM/randsum/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RANDSUM/randsum.git",
    "directory": "packages/roller"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/rollerTypes.d.ts",
        "default": "./dist/rollerTypes.js"
      },
      "require": {
        "types": "./dist/rollerTypes.d.cts",
        "default": "./dist/rollerTypes.cjs"
      }
    },
    "./errors": {
      "import": {
        "types": "./dist/rollerErrors.d.ts",
        "default": "./dist/rollerErrors.js"
      },
      "require": {
        "types": "./dist/rollerErrors.d.cts",
        "default": "./dist/rollerErrors.cjs"
      }
    },
    "./validate": {
      "import": {
        "types": "./dist/rollerValidate.d.ts",
        "default": "./dist/rollerValidate.js"
      },
      "require": {
        "types": "./dist/rollerValidate.d.cts",
        "default": "./dist/rollerValidate.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=18.0.0"
  },
  "keywords": [
    "dice",
    "roller",
    "rpg",
    "random",
    "typescript",
    "dnd",
    "tabletop",
    "dice-roller",
    "ttrpg",
    "dungeons-and-dragons",
    "pathfinder",
    "game-development",
    "board-games",
    "role-playing-games",
    "probability",
    "simulation",
    "randsum"
  ],
  "dependencies": {
    "@randsum/notation": "workspace:~"
  },
  "devDependencies": {
    "fast-check": "catalog:"
  },
  "scripts": {
    "dev": "bunup --watch",
    "prepublishOnly": "bun run build",
    "build": "bunup --entry src/index.ts --entry src/rollerTypes.ts --entry src/rollerErrors.ts --entry src/rollerValidate.ts --format esm,cjs --dts --no-splitting --minify --sourcemap external --target node --clean",
    "test": "bun test",
    "lint": "eslint . -c ../../eslint.config.js",
    "format": "prettier --write . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "typecheck": "tsc --noEmit"
  }
}
