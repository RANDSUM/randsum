{
  "$schema": "https://randsum.dev/schemas/v1/randsum.json",
  "name": "Fate Core",
  "shortcode": "fate",
  "version": "1.0.0",
  "game_url": "https://fate-srd.com/",
  "srd_url": "https://fate-srd.com/fate-core/",

  "pools": {
    "fateDice": { "faces": [-1, 0, 1] }
  },

  "outcomes": {
    "ladder": {
      "ranges": [
        { "min": 8, "result": "legendary" },
        { "exact": 7, "result": "epic" },
        { "exact": 6, "result": "fantastic" },
        { "exact": 5, "result": "superb" },
        { "exact": 4, "result": "great" },
        { "exact": 3, "result": "good" },
        { "exact": 2, "result": "fair" },
        { "exact": 1, "result": "average" },
        { "exact": 0, "result": "mediocre" },
        { "exact": -1, "result": "poor" },
        { "max": -2, "result": "terrible" }
      ]
    }
  },

  "roll": {
    "inputs": {
      "modifier": {
        "type": "integer",
        "minimum": -2,
        "maximum": 5,
        "default": 0,
        "description": "Skill rating (Fate ladder rung, Terrible -2 to Superb +5) added to the 4dF total"
      }
    },
    "dice": {
      "pool": { "$ref": "#/pools/fateDice" },
      "quantity": 4
    },
    "resolve": "sum",
    "postResolveModifiers": [{ "add": { "$input": "modifier" } }],
    "outcome": { "$ref": "#/outcomes/ladder" }
  }
}
