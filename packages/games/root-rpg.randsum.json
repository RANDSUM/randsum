{
  "$schema": "https://randsum.dev/schemas/v1/randsum.json",
  "name": "Root RPG",
  "shortcode": "root-rpg",
  "version": "1.0.0",
  "game_url": "https://magpiegames.com/root-the-rpg/",

  "roll": {
    "inputs": {
      "bonus": { "type": "integer", "minimum": -3, "maximum": 5 },
      "rollingWith": { "type": "string", "enum": ["Advantage", "Disadvantage"], "optional": true }
    },
    "dice": { "pool": { "sides": 6 }, "quantity": 2 },
    "resolve": "sum",
    "modify": [{ "add": { "$input": "bonus" } }],
    "outcome": {
      "ranges": [
        { "min": 10, "result": "strong_hit" },
        { "min": 7, "max": 9, "result": "weak_hit" },
        { "max": 6, "result": "miss" }
      ]
    },
    "when": [
      {
        "condition": { "input": "rollingWith", "operator": "=", "value": "Advantage" },
        "override": {
          "dice": { "pool": { "sides": 6 }, "quantity": 3 },
          "modify": [{ "keepHighest": 2 }, { "add": { "$input": "bonus" } }]
        }
      },
      {
        "condition": { "input": "rollingWith", "operator": "=", "value": "Disadvantage" },
        "override": {
          "dice": { "pool": { "sides": 6 }, "quantity": 3 },
          "modify": [{ "keepLowest": 2 }, { "add": { "$input": "bonus" } }]
        }
      }
    ]
  }
}
