{
  "$schema": "https://randsum.dev/schemas/v1/randsum.json",
  "name": "Test Game",
  "shortcode": "test",
  "version": "1.0.0",
  "game_url": "https://example.com/test-game",
  "pools": { "d6": { "sides": 6 } },
  "tables": {
    "basic": {
      "ranges": [
        { "exact": 6, "result": "high" },
        { "min": 1, "max": 5, "result": "low" }
      ]
    }
  },
  "roll": {
    "inputs": { "count": { "type": "integer", "minimum": 1, "default": 1 } },
    "dice": { "pool": { "$ref": "#/pools/d6" }, "quantity": { "$input": "count" } },
    "modify": [{ "keepHighest": 1 }],
    "resolve": "sum",
    "outcome": { "tableLookup": { "$ref": "#/tables/basic" } }
  }
}
