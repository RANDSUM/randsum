{
  "name": "randsum-monorepo",
  "private": true,
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@eslint/js": "10.0.1",
    "@size-limit/preset-small-lib": "12.1.0",
    "@types/bun": "catalog:",
    "bunup": "0.16.32",
    "dependency-cruiser": "17.4.3",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "knip": "6.16.1",
    "lefthook": "2.1.9",
    "mitata": "catalog:",
    "prettier": "3.8.4",
    "prettier-plugin-astro": "0.14.1",
    "size-limit": "12.1.0",
    "typedoc": "0.28.19",
    "typescript": "catalog:",
    "typescript-eslint": "8.61.0"
  },
  "engines": {
    "node": ">=22.14.0",
    "bun": ">=1.3.14"
  },
  "catalog": {
    "fast-check": "4.8.0",
    "@types/bun": "1.3.14",
    "mitata": "1.0.34",
    "typescript": "6.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  },
  "overrides": {
    "undici": ">=6.27.0 <7",
    "yaml": ">=2.8.3",
    "esbuild": ">=0.28.1",
    "@opentelemetry/core": ">=2.8.0",
    "@opentelemetry/resources": ">=2.8.0",
    "@opentelemetry/sdk-trace-base": ">=2.8.0",
    "@opentelemetry/sdk-trace-node": ">=2.8.0",
    "@opentelemetry/context-async-hooks": ">=2.8.0"
  },
  "scripts": {
    "prepare": "[ -d .git ] && (git config --unset-all --local core.hooksPath 2>/dev/null; lefthook install) || true",
    "help": "bun scripts/help.ts",
    "check:workspace-scripts": "bun scripts/check-workspace-scripts.ts",
    "build": "bun run --filter '@randsum/roller' build && bun run --filter '@randsum/games' build && bun run --filter '@randsum/cli' --filter '@randsum/discord-bot' --filter '@randsum/mcp' build",
    "test": "bun run --filter '*' test",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-dir=./coverage",
    "lint": "bun run --filter '@randsum/*' lint",
    "format": "bun run --filter '@randsum/*' format",
    "format:check": "bun run --filter '@randsum/*' format:check",
    "typecheck": "bun run --filter '@randsum/*' typecheck",
    "size": "bun run --filter '*' size",
    "check": "bun run check:workspace-scripts && bun run --filter '@randsum/roller' check && bun run --filter '@randsum/games' check && bun run --filter '@randsum/cli' check && bun run --filter '@randsum/mcp' check && bun run --filter '@randsum/discord-bot' check && bun run --filter '@randsum/site' check && bun run --filter '@randsum/rdn' check && bun run --filter '@randsum/dice-ui' check",
    "bench": "bun run packages/roller/__benchmarks__/roll.bench.ts",
    "bench:ci": "bun scripts/bench-ci.ts",
    "profile": "bun --cpu-prof packages/roller/__benchmarks__/roll.bench.ts",
    "profile:md": "bun --cpu-prof-md packages/roller/__benchmarks__/roll.bench.ts",
    "knip": "knip --exclude catalog --no-config-hints",
    "arch:check": "depcruise packages apps --config .dependency-cruiser.cjs",
    "docs:api": "typedoc",
    "fix:all": "bun run lint -- --fix && bun run format",
    "site:build": "bun --filter @randsum/site build",
    "site:dev": "bun run --filter @randsum/site dev",
    "rdn:build": "bun run --filter @randsum/rdn build",
    "rdn:dev": "bun run --filter @randsum/rdn dev",
    "changeset": "bunx changeset",
    "version-packages": "bunx changeset version",
    "publish": "bun run build && bun run check && bun scripts/publish.ts"
  },
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ]
}
