{
  "name": "randsum-monorepo",
  "private": true,
  "devDependencies": {
    "@astrojs/netlify": "7.0.1",
    "@eslint/js": "10.0.1",
    "@size-limit/preset-small-lib": "12.0.1",
    "@types/bun": "1.3.10",
    "@typescript-eslint/eslint-plugin": "8.57.0",
    "@typescript-eslint/parser": "8.57.0",
    "astro": "6.0.2",
    "bunup": "0.16.31",
    "devalue": "5.6.4",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "fast-check": "4.6.0",
    "flatted": "3.4.1",
    "lefthook": "2.1.3",
    "mitata": "1.0.34",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "size-limit": "12.0.1",
    "ts-unused-exports": "11.0.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "undici": "6.24.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.3.10"
  },
  "catalog": {
    "fast-check": "4.6.0",
    "@types/bun": "1.3.10",
    "mitata": "1.0.34",
    "typescript": "5.9.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "size-limit": [
    {
      "path": "packages/notation/dist/index.js",
      "limit": "13 KB"
    },
    {
      "path": "packages/roller/dist/index.js",
      "limit": "10 KB"
    },
    {
      "path": "packages/display-utils/dist/index.js",
      "limit": "20 KB"
    },
    {
      "path": "packages/component-library/dist/index.js",
      "limit": "50 KB"
    },
    {
      "path": "packages/games/dist/blades.generated.js",
      "limit": "8 KB"
    },
    {
      "path": "packages/games/dist/fifth.generated.js",
      "limit": "8 KB"
    },
    {
      "path": "packages/games/dist/daggerheart.generated.js",
      "limit": "8 KB"
    },
    {
      "path": "packages/games/dist/pbta.generated.js",
      "limit": "8 KB"
    },
    {
      "path": "packages/games/dist/root-rpg.generated.js",
      "limit": "8 KB"
    },
    {
      "path": "packages/games/dist/salvageunion.generated.js",
      "limit": "100 KB"
    },
    {
      "path": "packages/roller/dist/index.d.ts",
      "limit": "5 KB"
    },
    {
      "path": "packages/notation/dist/index.d.ts",
      "limit": "4 KB"
    },
    {
      "path": "packages/display-utils/dist/index.d.ts",
      "limit": "2 KB"
    }
  ],
  "scripts": {
    "prepare": "[ -d .git ] && lefthook install || true",
    "help": "bun scripts/help.ts",
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '@randsum/roller' --filter '@randsum/notation' build && bun run --filter '@randsum/display-utils' build && bun run --filter '@randsum/games' --filter '@randsum/component-library' --filter '@randsum/cli' --filter '@randsum/discord-bot' build",
    "test": "bun test --recursive",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-dir=./coverage",
    "lint": "bun run --filter \"*\" lint",
    "format": "bun run --filter \"*\" format",
    "format:check": "bun run --filter \"*\" format:check",
    "typecheck": "bun run --filter \"*\" typecheck",
    "size": "size-limit",
    "size:check": "size-limit --json",
    "check:exports": "ts-unused-exports tsconfig.json --ignoreFiles='__tests__|test-utils|[\\\\/]dist[\\\\/]' --maxIssues=50",
    "bench": "bun run packages/roller/__benchmarks__/roll.bench.ts",
    "bench:ci": "bun run packages/roller/__benchmarks__/roll.bench.ts --json > benchmark-results.json",
    "profile": "bun --cpu-prof packages/roller/__benchmarks__/roll.bench.ts",
    "profile:md": "bun --cpu-prof-md packages/roller/__benchmarks__/roll.bench.ts",
    "check:all": "bun run lint && bun run format:check && bun run typecheck && bun test && bun run build && bun run size && bun run check:exports && bun run site:build",
    "fix:all": "bun run lint -- --fix && bun run format",
    "site:build": "bun --filter @randsum/site build",
    "site:dev": "bun run --filter @randsum/component-library dev & bun run --filter @randsum/site dev",
    "stories": "bun run --filter @randsum/component-library ladle",
    "discord:dev": "cd apps/discord-bot && bun run dev",
    "discord:deploy": "cd apps/discord-bot && bun run deploy-commands",
    "discord:start": "cd apps/discord-bot && bun run start",
    "discord:build": "bun --filter @randsum/discord-bot build",
    "discord:lint": "bun --filter @randsum/discord-bot lint",
    "discord:format": "bun --filter @randsum/discord-bot format",
    "discord:typecheck": "bun --filter @randsum/discord-bot typecheck",
    "version": "bun pm version",
    "version:patch": "bun pm version patch",
    "version:minor": "bun pm version minor",
    "version:major": "bun pm version major",
    "publish": "bun run lint && bun run format:check && bun run typecheck && bun run test && bun run build && bun run size && bun run check:exports && bun scripts/publish.ts"
  },
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/cli",
    "apps/discord-bot",
    "apps/site"
  ],
  "overrides": {
    "lodash": "4.17.23",
    "markdown-it": "14.1.1",
    "mdast-util-to-hast": "13.2.1",
    "undici": "6.24.0",
    "tar": "7.5.11",
    "devalue": "5.6.4",
    "flatted": "3.4.1",
    "yauzl": "3.2.1"
  }
}
