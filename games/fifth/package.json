{
  "name": "@randsum/fifth",
  "version": "3.0.0",
  "description": "D&D 5th Edition dice roller with advantage, disadvantage, and modifier support for type-safe 5e apps",
  "private": false,
  "author": {
    "name": "Alex Jarvis",
    "url": "https://github.com/alxjrvs"
  },
  "license": "MIT",
  "homepage": "https://randsum.dev/games/fifth/",
  "bugs": "https://github.com/RANDSUM/randsum/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RANDSUM/randsum.git",
    "directory": "games/fifth"
  },
  "main": "./dist/fifth.generated.cjs",
  "module": "./dist/fifth.generated.js",
  "types": "./dist/fifth.generated.d.ts",
  "files": [
    "dist",
    "fifth.randsum.json",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "dependencies": {
    "@randsum/gameSchema": "workspace:~"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/fifth.generated.d.ts",
        "default": "./dist/fifth.generated.js"
      },
      "require": {
        "types": "./dist/fifth.generated.d.cts",
        "default": "./dist/fifth.generated.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=18.0.0"
  },
  "keywords": [
    "dice",
    "roller",
    "rpg",
    "typescript",
    "dnd",
    "5e",
    "d20",
    "dungeons-and-dragons",
    "tabletop",
    "ttrpg",
    "advantage",
    "dice-roller"
  ],
  "scripts": {
    "prepublishOnly": "bun run build",
    "build": "bun run randsum-schema-build",
    "validate": "bun run randsum-schema-validate",
    "test": "bun run build && bun test"
  }
}
