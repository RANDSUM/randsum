{
  "name": "@randsum/pbta",
  "version": "3.0.0",
  "description": "A flexible, type-safe dice roller for Powered by the Apocalypse games",
  "private": false,
  "author": {
    "name": "Alex Jarvis",
    "url": "https://github.com/alxjrvs"
  },
  "type": "module",
  "license": "MIT",
  "homepage": "https://randsum.dev/games/pbta/",
  "bugs": "https://github.com/RANDSUM/randsum/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RANDSUM/randsum.git",
    "directory": "games/pbta"
  },
  "main": "./dist/pbta.generated.cjs",
  "module": "./dist/pbta.generated.js",
  "types": "./dist/pbta.generated.d.ts",
  "files": [
    "dist",
    "pbta.randsum.json",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@randsum/gameSchema": "workspace:~"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/pbta.generated.d.ts",
        "default": "./dist/pbta.generated.js"
      },
      "require": {
        "types": "./dist/pbta.generated.d.cts",
        "default": "./dist/pbta.generated.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=18.0.0"
  },
  "keywords": [
    "dice",
    "roller",
    "rpg",
    "random",
    "typescript",
    "tabletop",
    "pbta",
    "powered-by-the-apocalypse",
    "dungeon-world",
    "monster-of-the-week"
  ],
  "scripts": {
    "prepublishOnly": "bun run build",
    "build": "bun run randsum-schema-build",
    "validate": "bun run randsum-schema-validate",
    "test": "bun run build && bun test"
  }
}
