{
  "name": "@randsum/blades",
  "version": "3.0.0",
  "description": "Blades in the Dark dice roller with critical, success, partial, and failure outcomes for Forged in the Dark apps",
  "private": false,
  "author": {
    "name": "Alex Jarvis",
    "url": "https://github.com/alxjrvs"
  },
  "license": "MIT",
  "homepage": "https://randsum.dev/games/blades/",
  "bugs": "https://github.com/RANDSUM/randsum/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RANDSUM/randsum.git",
    "directory": "games/blades"
  },
  "type": "module",
  "main": "./dist/blades.cjs",
  "module": "./dist/blades.js",
  "types": "./dist/blades.d.ts",
  "files": [
    "dist",
    "blades.randsum.json",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@randsum/gameSchema": "workspace:~"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/blades.d.ts",
        "default": "./dist/blades.js"
      },
      "require": {
        "types": "./dist/blades.d.cts",
        "default": "./dist/blades.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=18.0.0"
  },
  "keywords": [
    "dice",
    "roller",
    "rpg",
    "random",
    "typescript",
    "tabletop",
    "blades",
    "forged-in-the-dark"
  ],
  "scripts": {
    "prepublishOnly": "bun run build",
    "build": "bun run randsum-schema-build",
    "validate": "bun run randsum-schema-validate",
    "test": "bun run build && bun test"
  }
}
