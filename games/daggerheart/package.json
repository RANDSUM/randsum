{
  "name": "@randsum/daggerheart",
  "version": "3.0.0",
  "description": "Daggerheart RPG dice roller with hope/fear dice, amplification, and extra die (d6 add/subtract) support",
  "private": false,
  "author": {
    "name": "Alex Jarvis",
    "url": "https://github.com/alxjrvs"
  },
  "license": "MIT",
  "homepage": "https://randsum.dev/games/daggerheart/",
  "bugs": "https://github.com/RANDSUM/randsum/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RANDSUM/randsum.git",
    "directory": "games/daggerheart"
  },
  "main": "./dist/daggerheart.generated.cjs",
  "module": "./dist/daggerheart.generated.js",
  "types": "./dist/daggerheart.generated.d.ts",
  "files": [
    "dist",
    "daggerheart.randsum.json",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "dependencies": {
    "@randsum/gameSchema": "workspace:~"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/daggerheart.generated.d.ts",
        "default": "./dist/daggerheart.generated.js"
      },
      "require": {
        "types": "./dist/daggerheart.generated.d.cts",
        "default": "./dist/daggerheart.generated.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=18.0.0"
  },
  "keywords": [
    "dice",
    "roller",
    "rpg",
    "random",
    "typescript",
    "tabletop",
    "daggerheart",
    "hope",
    "fear",
    "darrington-press"
  ],
  "scripts": {
    "prepublishOnly": "bun run build",
    "build": "bun run randsum-schema-build",
    "validate": "bun run randsum-schema-validate",
    "test": "bun run build && bun test"
  }
}
