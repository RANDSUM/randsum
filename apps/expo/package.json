    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "7.15.6",
    "@react-navigation/native": "7.1.34",
    "@supabase/supabase-js": "^2.49.4",
    "expo": "~55.0.8",
    "expo-constants": "~55.0.9",
    "expo-crypto": "~55.0.10",
    "expo-font": "55.0.4",
    "expo-haptics": "55.0.9",
    "expo-linking": "~55.0.8",
    "expo-router": "~55.0.7",
