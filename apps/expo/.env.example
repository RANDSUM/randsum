# @randsum/expo environment variables
#
# Copy this file to `.env.local` and fill in real values.
# NOTE (2026-06-13): The app currently runs with NO secrets — none of these are read by the
# code today. Supabase auth + cloud sync were removed on 2026-03-25 and are planned to return
# (see PRD.md and CLAUDE.md "Known Gotchas"). This file documents the variables the app will
# need when Supabase is re-introduced, so the contract is captured ahead of time.
#
# In Expo, only variables prefixed with EXPO_PUBLIC_ are inlined into the client bundle.
# Never put a server-side service-role key in an EXPO_PUBLIC_ variable — those ship to users.

# Supabase project URL (client-safe, public)
EXPO_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (client-safe — RLS enforces access; NOT the service_role key)
EXPO_PUBLIC_SUPABASE_ANON_KEY=
