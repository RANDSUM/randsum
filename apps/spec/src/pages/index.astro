---
import { getCollection, render } from 'astro:content'
import { getLatestVersion } from '../utils/versions'

const latestId = await getLatestVersion()
const entries = await getCollection('specs')
const entry = entries.find((e) => e.id === latestId)
if (!entry) throw new Error(`No spec entry found for version: ${latestId}`)
const { Content } = await render(entry)
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RANDSUM Dice Notation Specification</title>
  </head>
  <body>
    <Content />
  </body>
</html>
