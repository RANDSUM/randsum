---
import { getCollection, render } from 'astro:content'
import { isLatestVersion } from '../../utils/versions'
import SpecLayout from '../../layouts/SpecLayout.astro'

export async function getStaticPaths() {
  const entries = await getCollection('specs')
  return entries.map((entry) => ({
    params: { version: entry.id },
    props: { entry }
  }))
}

const { entry } = Astro.props
const { version } = Astro.params
const { Content } = await render(entry)
const latest = await isLatestVersion(version)
---

<SpecLayout
  title="RANDSUM Dice Notation Specification"
  version={version}
  isLatest={latest}
>
  <div slot="content">
    {!latest && (
      <p style="margin-bottom: 1.5rem;">
        <a href="/" style="color: var(--accent);">&larr; Back to latest</a>
      </p>
    )}
    <Content />
  </div>
</SpecLayout>
