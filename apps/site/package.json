{
  "name": "@randsum/site",
  "version": "1.1.2",
  "description": "RANDSUM documentation and marketing website built with Astro",
  "private": true,
  "sideEffects": false,
  "author": {
    "name": "Alex Jarvis",
    "url": "https://github.com/alxjrvs"
  },
  "license": "MIT",
  "homepage": "https://github.com/RANDSUM/randsum",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RANDSUM/randsum.git",
    "directory": "apps/site"
  },
  "type": "module",
  "dependencies": {
    "@astrojs/netlify": "7.0.1",
    "@astrojs/react": "5.0.3",
    "@astrojs/starlight": "0.38.0",
    "@randsum/dice-ui": "workspace:~",
    "@randsum/roller": "workspace:~",
    "@stackblitz/sdk": "latest",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "astro": "6.0.2",
    "astro-expressive-code": "0.41.7",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0",
    "bun": ">=1.3.10"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "bun test",
    "lint": "eslint . -c ../../eslint.config.js",
    "format": "prettier --write . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "typecheck": "astro check",
    "check": "bun run build && bun run typecheck && bun run format:check && bun run lint && bun run test"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.7",
    "@astrojs/sitemap": "3.7.2",
    "starlight-page-actions": "0.5.0",
    "starlight-sidebar-topics": "0.7.1"
  }
}
