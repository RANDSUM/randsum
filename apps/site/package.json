{
  "name": "@randsum/site",
  "version": "1.0.0",
  "description": "RANDSUM documentation and marketing website built with Astro",
  "private": true,
  "sideEffects": false,
  "author": {
    "name": "Alex Jarvis",
    "url": "https://github.com/alxjrvs"
  },
  "license": "MIT",
  "homepage": "https://github.com/RANDSUM/randsum",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RANDSUM/randsum.git",
    "directory": "apps/site"
  },
  "type": "module",
  "dependencies": {
    "@astrojs/netlify": "^6.6.4",
    "@astrojs/react": "^4.4.2",
    "@astrojs/starlight": "^0.34.0",
    "@monaco-editor/react": "4.7.0",
    "@randsum/blades": "workspace:~",
    "@randsum/daggerheart": "workspace:~",
    "@randsum/fifth": "workspace:~",
    "@randsum/pbta": "workspace:~",
    "@randsum/roller": "workspace:~",
    "@randsum/root-rpg": "workspace:~",
    "@randsum/salvageunion": "workspace:~",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "astro": "^5.18.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-syntax-highlighter": "16.1.1",
    "sucrase": "3.35.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.3.10"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "bun test",
    "lint": "eslint . -c ../../eslint.config.js",
    "format": "prettier --write . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/react-syntax-highlighter": "15.5.13"
  }
}
