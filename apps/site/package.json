{
  "name": "@randsum/site",
  "version": "1.1.2",
  "description": "RANDSUM documentation and marketing website built with Astro",
  "private": true,
  "sideEffects": false,
  "author": {
    "name": "Alex Jarvis",
    "url": "https://github.com/alxjrvs"
  },
  "license": "MIT",
  "homepage": "https://github.com/RANDSUM/randsum",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RANDSUM/randsum.git",
    "directory": "apps/site"
  },
  "type": "module",
  "dependencies": {
    "@astrojs/netlify": "8.1.1",
    "@astrojs/react": "6.0.1",
    "@astrojs/starlight": "0.41.3",
    "@randsum/dice-ui": "workspace:~",
    "@randsum/roller": "workspace:~",
    "@stackblitz/sdk": "~1.11.0",
    "astro": "7.0.6",
    "astro-expressive-code": "0.44.0",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0",
    "bun": ">=1.3.10"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "bun test",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "astro check",
    "check": "bun run build && bun run typecheck && bun run format:check && bun run lint && bun run test"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/sitemap": "3.7.3",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "starlight-page-actions": "0.6.2",
    "starlight-sidebar-topics": "0.8.0",
    "typescript": "7.0.2"
  }
