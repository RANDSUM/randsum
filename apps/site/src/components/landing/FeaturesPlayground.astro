---
import { HeroRollerPlayground } from '../HeroInteractive'
---

<section class="features-section">
  <div class="section-inner">
    <div class="features-playground-row">
      <div class="playground-col not-content">
        <HeroRollerPlayground client:only="react" />
      </div>
      <div class="playground-pitch">
        <h2 class="pitch-heading">
          <span class="pitch-plain">Every </span><span class="pitch-purple">modifier</span><span class="pitch-plain">,</span>
          <br />
          <span class="pitch-color-cycle" aria-label="parsed">{"parsed".split('').map((c, i) => <span class="pitch-color-char" style={`animation-delay: ${i * 0.15}s`}>{c}</span>)}</span>
          <span class="pitch-plain"> and </span>
          <span class="pitch-color-cycle" aria-label="validated">{"validated".split('').map((c, i) => <span class="pitch-color-char" style={`animation-delay: ${(i + 6) * 0.15}s`}>{c}</span>)}</span>
          <span class="pitch-plain">.</span>
        </h2>
        <p class="pitch-body">
          <code>@randsum/roller</code> is a zero-dependency dice engine with a complete notation spec &mdash; fully specified, documented, and implemented. Every common rolling pattern covered so you never have to invent your own.
        </p>
        <div class="pitch-actions">
          <a href="https://randsum.io" class="btn btn-outline btn-sm" target="_blank" rel="noopener noreferrer">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="3" ry="3"/><circle cx="8" cy="8" r="1.5" fill="currentColor" stroke="none"/><circle cx="16" cy="8" r="1.5" fill="currentColor" stroke="none"/><circle cx="8" cy="16" r="1.5" fill="currentColor" stroke="none"/><circle cx="16" cy="16" r="1.5" fill="currentColor" stroke="none"/></svg>
            Playground
          </a>
          <a href="https://notation.randsum.dev" class="btn btn-outline btn-sm" target="_blank" rel="noopener noreferrer">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            RDN Spec
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
