---
import { GameSchemaViewer } from '../GameSchemaViewer'
---

<section class="game-schema-section">
  <div class="section-inner">
    <div class="game-schema-row">
      <div class="game-schema-pitch">
        <h2 class="pitch-heading">
          <span class="pitch-plain">Define </span>
          <span class="pitch-game-cycle">Rules</span>
          <span class="pitch-plain">,</span>
          <br />
          <span class="pitch-plain">get </span>
          <span class="pitch-purple">Rolls</span>
          <span class="pitch-plain">.</span>
        </h2>
        <p class="pitch-body">
          Describe your game&rsquo;s mechanics in a <code>.randsum.json</code> spec and <code
            >@randsum/games</code
          > generates a bespoke, fully-typed roller for that system. Adding a new game is just writing
          a config file.
        </p>
        <div class="pitch-actions">
          <a href="/games/introduction/" class="btn btn-outline btn-sm">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path
                d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg
            >
            Game Packages
          </a>
          <a href="/games/schema/overview/" class="btn btn-outline btn-sm">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline
                points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line
                x1="16"
                y1="17"
                x2="8"
                y2="17"></line></svg
            >
            Games Schema
          </a>
        </div>
      </div>
      <div class="game-schema-viewer-col not-content">
        <GameSchemaViewer client:only="react" />
      </div>
    </div>
  </div>
</section>
