---
import { Code } from 'astro-expressive-code/components'
import { ClickableTagline } from '../HeroInteractive'

const codeExample = [
  "import { roll } from '@randsum/roller'",
  '',
  "const { total, rolls } = roll('4d6L')",
  '',
  'console.log(total)',
  '// 15',
  'console.log(rolls[0].initialRolls)',
  '// [1, 5, 4, 6]',
  'console.log(rolls[0].rolls)',
  '// [4, 5, 6]',
  'console.log(rolls[0].description)',
  '// ["Roll 4 6-sided dice", "Drop lowest"]'
].join('\n')

const stackblitzNotation = '4d6L'
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-lockup">
      <div class="hero-text">
        <ClickableTagline client:load />
        <p class="hero-subtitle">A Zero Dependency, Typescript-First, Bun-Native Dice Notation and Rolling Engine.</p>
        <div class="hero-actions">
          <a href="/welcome/introduction/" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            Get Started
          </a>
          <a href="https://github.com/RANDSUM/randsum" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            GitHub
          </a>
        </div>
        <div class="hero-install-row">
          <button class="install-cmd" data-cmd="bun add @randsum/roller" aria-label="Copy bun install command">
            <code>bun add @randsum/roller</code>
            <span class="install-copy-icon" aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg></span>
          </button>
          <button class="install-cmd" data-cmd="npm i @randsum/roller" aria-label="Copy npm install command">
            <code>npm i @randsum/roller</code>
            <span class="install-copy-icon" aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg></span>
          </button>
        </div>
      </div>
      <div class="hero-code not-content">
        <div class="code-example">
          <div class="code-example-chrome">
            <div class="code-chrome-dots">
              <span class="code-chrome-dot code-chrome-dot--red"></span>
              <span class="code-chrome-dot code-chrome-dot--yellow"></span>
              <span class="code-chrome-dot code-chrome-dot--green"></span>
            </div>
            <span class="code-chrome-filename">index.ts</span>
            <button class="code-example-stackblitz" data-notation={stackblitzNotation} aria-label="Edit in StackBlitz" title="Edit in StackBlitz">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            </button>
          </div>
          <Code code={codeExample} lang="typescript" />
        </div>
      </div>
    </div>
  </div>
</section>
