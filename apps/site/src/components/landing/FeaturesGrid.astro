---
import LabeledSection from '../LabeledSection.astro'
---

<LabeledSection label="Features" labelSide="left">
  <div class="pkg-grid feature-grid">
    <div
      class="pkg-card feature-card"
      style="--card-accent: var(--sl-color-accent); --card-hover-text: #fff"
    >
      <div class="pkg-card-header"><h3 class="pkg-card-name">Zero Dependencies</h3></div>
    </div>
    <div
      class="pkg-card feature-card"
      style="--card-accent: var(--sl-color-accent); --card-hover-text: #fff"
    >
      <div class="pkg-card-header"><h3 class="pkg-card-name">TypeScript First</h3></div>
    </div>
    <div
      class="pkg-card feature-card"
      style="--card-accent: var(--sl-color-accent); --card-hover-text: #fff"
    >
      <div class="pkg-card-header"><h3 class="pkg-card-name">Bun Native</h3></div>
    </div>
    <a
      class="pkg-card feature-card"
      style="--card-accent: var(--sl-color-accent); --card-hover-text: #fff"
      href="https://notation.randsum.dev"
      target="_blank"
      rel="noopener noreferrer"
    >
      <div class="pkg-card-header"><h3 class="pkg-card-name">RDN Spec</h3></div>
    </a>
    <div
      class="pkg-card feature-card"
      style="--card-accent: var(--sl-color-accent); --card-hover-text: #fff"
    >
      <div class="pkg-card-header"><h3 class="pkg-card-name">Game Support</h3></div>
    </div>
    <div
      class="pkg-card feature-card"
      style="--card-accent: var(--sl-color-accent); --card-hover-text: #fff"
    >
      <div class="pkg-card-header"><h3 class="pkg-card-name">ESM Only</h3></div>
    </div>
    <div
      class="pkg-card feature-card"
      style="--card-accent: var(--sl-color-accent); --card-hover-text: #fff"
    >
      <div class="pkg-card-header"><h3 class="pkg-card-name">Under 20KB</h3></div>
    </div>
    <div
      class="pkg-card feature-card"
      style="--card-accent: var(--sl-color-accent); --card-hover-text: #fff"
    >
      <div class="pkg-card-header"><h3 class="pkg-card-name">26 Modifiers</h3></div>
    </div>
  </div>
</LabeledSection>
