---
import { Code } from '@astrojs/starlight/components'
import { OpenInStackBlitz } from './OpenInStackBlitz'

interface Props {
  code: string
  lang?: string
  readonly?: boolean
}

const { code, lang = 'typescript', readonly = false } = Astro.props
const isTypeScript = lang === 'typescript'
---

<Code code={code} lang={lang} />
{isTypeScript && !readonly && <OpenInStackBlitz code={code} client:visible />}
