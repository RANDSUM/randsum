---
import Default from '@astrojs/starlight/components/PageTitle.astro'

const { entry, id } = Astro.props as { entry?: { data?: { description?: string } }; id?: string }
const description = entry?.data?.description
const slug = id ?? ''
const sourceUrl = `https://github.com/RANDSUM/randsum/tree/main/apps/site/src/content/docs/${slug}.mdx`
const pageUrl = `https://randsum.dev/${slug.replace(/\/$/, '')}/`
---

<Default {...Astro.props}><slot /></Default>

{description && (
  <p class="page-description">{description}</p>
)}

<div class="page-toolbar">
  <button class="toolbar-btn toolbar-copy-md" data-page-url={pageUrl} aria-label="Copy as Markdown">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
    <span class="toolbar-label">Copy Markdown</span>
  </button>
  <div class="toolbar-dropdown">
    <button class="toolbar-btn toolbar-open-toggle" aria-label="Open in editor" aria-expanded="false">
      <span class="toolbar-label">Open</span>
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
    </button>
    <div class="toolbar-menu" hidden>
      <a class="toolbar-menu-item" href={sourceUrl} target="_blank" rel="noopener noreferrer">
        <svg width="14" height="14" viewBox="0 0 16 16"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        <span>Open in GitHub</span>
        <svg class="toolbar-menu-ext" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
      <a class="toolbar-menu-item" href={`https://chatgpt.com/?hints=search&q=${encodeURIComponent(`Read this page and summarize: ${pageUrl}`)}`} target="_blank" rel="noopener noreferrer">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
        <span>Open in ChatGPT</span>
        <svg class="toolbar-menu-ext" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
      <a class="toolbar-menu-item" href={`https://claude.ai/new?q=${encodeURIComponent(`Read this page and summarize: ${pageUrl}`)}`} target="_blank" rel="noopener noreferrer">
        <span class="toolbar-menu-icon-text">A\</span>
        <span>Open in Claude</span>
        <svg class="toolbar-menu-ext" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
    </div>
  </div>
</div>

<style>
  .page-description {
    font-size: 1rem;
    color: var(--sl-color-gray-2);
    margin: -0.5rem 0 0.75rem;
    line-height: 1.5;
  }

  .page-toolbar {
    display: flex;
    align-items: center;
    gap: 0;
    margin: 0 0 1.5rem;
  }

  .toolbar-btn {
    appearance: none;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    height: 2rem;
    padding: 0 0.75rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--sl-color-gray-2);
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    cursor: pointer;
    transition: color 0.15s ease, background 0.15s ease;
  }

  .toolbar-copy-md {
    border-radius: var(--sl-border-radius, 5px) 0 0 var(--sl-border-radius, 5px);
    border-right: none;
  }

  .toolbar-open-toggle {
    border-radius: 0 var(--sl-border-radius, 5px) var(--sl-border-radius, 5px) 0;
  }

  .toolbar-btn:hover {
    color: var(--sl-color-white);
    background: var(--sl-color-gray-5);
  }

  .toolbar-label {
    white-space: nowrap;
  }

  .toolbar-dropdown {
    position: relative;
  }

  .toolbar-menu {
    position: absolute;
    top: calc(100% + 4px);
    right: 0;
    min-width: 12rem;
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: var(--sl-border-radius, 5px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
    z-index: 100;
    padding: 0.25rem 0;
  }

  .toolbar-menu-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.8rem;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    transition: background 0.1s ease, color 0.1s ease;
  }

  .toolbar-menu-item:hover {
    background: var(--sl-color-gray-5);
    color: var(--sl-color-white);
  }

  .toolbar-menu-icon-text {
    font-weight: 700;
    font-size: 0.75rem;
    width: 14px;
    text-align: center;
  }

  .toolbar-menu-ext {
    margin-left: auto;
    opacity: 0.4;
  }
</style>

<script>
  // Copy Markdown
  document.querySelectorAll<HTMLButtonElement>('.toolbar-copy-md').forEach(btn => {
    btn.addEventListener('click', async () => {
      const content = document.querySelector('.sl-markdown-content')
      if (!content) return
      // Get text content, preserving basic structure
      const text = (content as HTMLElement).innerText ?? content.textContent ?? ''
      await navigator.clipboard.writeText(text)
      const label = btn.querySelector('.toolbar-label')
      if (label) {
        const orig = label.textContent
        label.textContent = 'Copied!'
        setTimeout(() => { label.textContent = orig }, 1500)
      }
    })
  })

  // Dropdown toggle
  document.querySelectorAll<HTMLButtonElement>('.toolbar-open-toggle').forEach(btn => {
    const menu = btn.parentElement?.querySelector('.toolbar-menu') as HTMLElement | null
    if (!menu) return

    btn.addEventListener('click', (e) => {
      e.stopPropagation()
      const isHidden = menu.hidden
      menu.hidden = !isHidden
      btn.setAttribute('aria-expanded', String(isHidden))
    })

    document.addEventListener('click', () => {
      menu.hidden = true
      btn.setAttribute('aria-expanded', 'false')
    })

    menu.addEventListener('click', (e) => {
      e.stopPropagation()
    })
  })
</script>
