---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro'
import LandingHero from '../components/landing/LandingHero.astro'
import FeaturesPlayground from '../components/landing/FeaturesPlayground.astro'
import GameSchemaSection from '../components/landing/GameSchemaSection.astro'
import IntegrationsSection from '../components/landing/IntegrationsSection.astro'
import FeaturesGrid from '../components/landing/FeaturesGrid.astro'
import PackagesGrid from '../components/landing/PackagesGrid.astro'
import GamesGrid from '../components/landing/GamesGrid.astro'
import ToolsGrid from '../components/landing/ToolsGrid.astro'
import LandingFooter from '../components/landing/LandingFooter.astro'
import LandingScripts from '../components/landing/LandingScripts.astro'
import '../styles/landing.css'
---

<StarlightPage
  frontmatter={{
    title: 'RANDSUM',
    description:
      'Zero-dependency TypeScript dice engine. Parse and roll 4d6L, 2d20H, exploding dice, and more. Pre-built for D&D 5e, Blades, and 4 more systems.',
    template: 'splash',
    head: [
      {
        tag: 'script',
        attrs: { type: 'application/ld+json' },
        content: JSON.stringify({
          '@context': 'https://schema.org',
          '@graph': [
            {
              '@type': 'WebSite',
              '@id': 'https://randsum.dev/#website',
              name: 'RANDSUM',
              url: 'https://randsum.dev/',
              description:
                'TypeScript-first dice notation ecosystem for tabletop RPGs. Zero-dependency dice engine with full notation support and game-specific packages.',
              publisher: { '@id': 'https://randsum.dev/#organization' }
            },
            {
              '@type': 'Organization',
              '@id': 'https://randsum.dev/#organization',
              name: 'RANDSUM',
              url: 'https://randsum.dev/',
              sameAs: ['https://github.com/RANDSUM/randsum', 'https://www.npmjs.com/org/randsum']
            }
          ]
        })
      }
    ]
  }}
  hasSidebar={false}
>
  <div class="landing">
    <LandingHero />

    <hr class="section-divider" />

    <FeaturesPlayground />

    <hr class="section-divider" />

    <GameSchemaSection />

    <hr class="section-divider" />

    <IntegrationsSection />

    <hr class="section-divider" />

    <FeaturesGrid />

    <PackagesGrid />

    <GamesGrid />

    <ToolsGrid />

    <LandingFooter />
  </div>
</StarlightPage>

<LandingScripts />
