{
  "name": "@randsum/rdn",
  "version": "1.0.0",
  "description": "RANDSUM Dice Notation Specification site at notation.randsum.dev",
  "private": true,
  "sideEffects": false,
  "author": {
    "name": "Alex Jarvis",
    "url": "https://github.com/alxjrvs"
  },
  "license": "MIT",
  "homepage": "https://notation.randsum.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RANDSUM/randsum.git",
    "directory": "apps/rdn"
  },
  "type": "module",
  "dependencies": {
    "astro": "6.1.6"
  },
  "engines": {
    "node": ">=22.12.0",
    "bun": ">=1.3.10"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "lint": "eslint . -c ../../eslint.config.js",
    "format": "prettier --write . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "check": "bun run build && bun run typecheck && bun run format:check && bun run lint",
    "conformance:gen": "bun conformance-gen.ts",
    "conformance:check": "bun conformance-gen.ts && git diff --exit-code public/conformance/v0.9.0.json"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.7",
    "@astrojs/sitemap": "3.7.2",
    "@randsum/roller": "workspace:~",
    "typescript": "5.8.3"
  }
}
