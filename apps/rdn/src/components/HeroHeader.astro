---
import VersionDropdown from './VersionDropdown.astro'

interface Props {
  version: string
  versions: string[]
  isLatest: boolean
}

const { version, versions, isLatest } = Astro.props
---

<header class="spec-hero">
  <div class="spec-hero-inner">
    <div class="spec-hero-text">
      <p class="label spec-hero-label">Specification</p>
      <h1 class="spec-hero-title">RANDSUM Dice Notation</h1>
      <p class="spec-hero-subtitle">
        A formal specification for dice notation syntax used in tabletop role-playing games.
      </p>
    </div>
    <div class="spec-hero-actions">
      {versions.length > 0 && (
        <VersionDropdown
          currentVersion={version}
          allVersions={versions}
          isLatest={isLatest}
        />
      )}
      <button
        class="theme-toggle"
        aria-label="Toggle light/dark mode"
        data-theme-toggle
      >
        <svg class="theme-icon theme-icon--sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/>
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
        <svg class="theme-icon theme-icon--moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
        </svg>
      </button>
      <a
        href="https://randsum.dev"
        class="spec-hero-github"
        aria-label="Documentation"
        target="_blank"
        rel="noopener noreferrer"
        title="Documentation"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 19.5A2.5 2.5 0 016.5 17H20"/>
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/>
        </svg>
      </a>
      <a
        href="https://randsum.io"
        class="spec-hero-github"
        aria-label="Playground"
        target="_blank"
        rel="noopener noreferrer"
        title="Playground"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <polygon points="5 3 19 12 5 21 5 3"/>
        </svg>
      </a>
      <a
        href="https://github.com/RANDSUM/randsum"
        class="spec-hero-github"
        aria-label="View source on GitHub"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
      </a>
    </div>
  </div>
</header>
