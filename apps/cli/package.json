{
  "name": "@randsum/cli",
  "version": "1.1.0",
  "description": "Dice rolling CLI and interactive TUI powered by RANDSUM",
  "private": false,
  "author": {
    "name": "Alex Jarvis",
    "url": "https://github.com/alxjrvs"
  },
  "license": "MIT",
  "homepage": "https://github.com/RANDSUM/randsum",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RANDSUM/randsum.git",
    "directory": "apps/cli"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "randsum": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "dice",
    "roller",
    "rpg",
    "cli",
    "tui",
    "terminal",
    "interactive",
    "randsum",
    "ttrpg",
    "dnd",
    "tabletop",
    "dice-roller"
  ],
  "dependencies": {
    "@randsum/roller": "^1.2.0",
    "ink": "^5.2.0",
    "ink-text-input": "^6.0.0",
    "react": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:"
  },
  "scripts": {
    "build": "bunup && chmod +x dist/index.js",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "lint": "eslint . -c ../../eslint.config.js",
    "format": "prettier --write . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=18.0.0"
  }
}
