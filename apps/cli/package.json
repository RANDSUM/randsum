{
  "name": "@randsum/cli",
  "version": "3.5.0",
  "description": "Dice rolling CLI and interactive TUI powered by RANDSUM",
  "private": false,
  "author": {
    "name": "Alex Jarvis",
    "url": "https://github.com/alxjrvs"
  },
  "license": "MIT",
  "homepage": "https://randsum.dev/tools/cli/",
  "bugs": "https://github.com/RANDSUM/randsum/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RANDSUM/randsum.git",
    "directory": "apps/cli"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "randsum": "dist/index.js"
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "dice",
    "roller",
    "rpg",
    "cli",
    "tui",
    "terminal",
    "interactive",
    "randsum",
    "ttrpg",
    "dnd",
    "tabletop",
    "dice-roller"
  ],
  "dependencies": {
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@randsum/roller": "workspace:~"
  },
  "scripts": {
    "build": "bunup && chmod +x dist/index.js",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "lint": "eslint . -c ../../eslint.config.js",
    "format": "prettier --write . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "check": "bun run build && bun run typecheck && bun run format:check && bun run lint && bun run test"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=18.0.0"
  }
}
