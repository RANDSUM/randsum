{
  "name": "@randsum/cli",
  "version": "0.1.0",
  "description": "Dice rolling CLI and interactive TUI powered by RANDSUM",
  "private": true,
  "author": {
    "name": "Alex Jarvis",
    "url": "https://github.com/alxjrvs"
  },
  "license": "MIT",
  "homepage": "https://github.com/RANDSUM/randsum",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RANDSUM/randsum.git",
    "directory": "apps/cli"
  },
  "type": "module",
  "bin": {
    "randsum": "dist/index.js"
  },
  "dependencies": {
    "@randsum/roller": "workspace:~",
    "ink": "^5.2.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18"
  },
  "scripts": {
    "build": "bunup --entry src/index.ts --format esm --dts --minify --sourcemap external --target node --clean && chmod +x dist/index.js",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "lint": "eslint . -c ../../eslint.config.js",
    "format": "prettier --write . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore --config ../../.prettierrc",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.3.8",
    "node": ">=18.0.0"
  }
}
