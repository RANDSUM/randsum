{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard", ":semanticCommits"],
  "timezone": "America/New_York",
  "schedule": ["before 6am on monday"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "rangeStrategy": "bump",
  "bun": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"]
  },
  "packageRules": [
    {
      "description": "Group non-major updates into a single weekly PR to reduce churn",
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "all non-major dependencies",
      "groupSlug": "all-minor-patch"
    },
    {
      "description": "Pin exact versions for devDependencies (they are pinned in this repo)",
      "matchDepTypes": ["devDependencies"],
      "rangeStrategy": "pin"
    },
    {
      "description": "Keep the bun catalog managed; single source of truth for shared versions",
      "matchManagers": ["bun"],
      "matchDepTypes": ["catalog"],
      "rangeStrategy": "replace"
    },
    {
      "description": "Track the undici override that Dependabot cannot see; hold within discord.js 14's tested 6.x major",
      "matchManagers": ["bun"],
      "matchDepNames": ["undici"],
      "allowedVersions": "<7"
    },
    {
      "description": "Major upgrades open individually and are not auto-grouped",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  }
}
